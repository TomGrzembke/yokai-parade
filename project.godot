; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="YokaiParade"
run/main_scene="res://game/game.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

BetterTerrain="*res://addons/better-terrain/BetterTerrain.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="viewport"
mouse_cursor/custom_image="res://assets/theme/cursor_point.png"
mouse_cursor/custom_image_hotspot=Vector2(17, 7)

[editor]

movie_writer/movie_file="C:/Users/fuzzy/Videos/Captures/yokai-parade.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/better-terrain/plugin.cfg")

[gui]

theme/custom="res://assets/theme/theme.tres"

